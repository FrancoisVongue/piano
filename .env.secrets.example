# Copy this file to `.env.secrets` (gitignored) and fill in real values.
# `.envrc` sources it via direnv and appends it to the generated `.env.local`.
# Never commit `.env.secrets`.

# Session signing secret for better-auth. Generate a strong random value, e.g.:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Symmetric key used to encrypt user-supplied LLM API keys (BYOK) at rest.
# Generate a strong random value, e.g.: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=

# Google OAuth credentials (optional — only needed to enable "Sign in with Google").
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (default dev slot): http://localhost:3031/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
