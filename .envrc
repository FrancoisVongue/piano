# ============================================================================
# .envrc — direnv config. Single source of truth for dev ports.
#
#   cd into this directory → direnv auto-loads all vars
#   cd out → vars are unloaded
#
# To run a second dev instance:  change SLOT to 1 (or 2, 3, 4), then:
#   direnv allow
#   just dev
#
# Each slot shifts every port by SLOT × 10. Five slots = five parallel
# instances, guaranteed collision-free (verified for all 50 port values).
# ============================================================================

SLOT=0
STRIDE=10

# Per-machine overrides — gitignored. Set EDGE_HOST here when running this
# Piano nested inside another (cookies bucket per-host, so outer/inner can
# coexist in the same browser):
#   export EDGE_HOST=piano.com   # or any /etc/hosts mapping you choose
source_env_if_exists .envrc.local

# --- Ports (computed, no duplication) ----------------------------------------
export BACKEND_PORT=$((3031 + SLOT * STRIDE))
export FRONTEND_PORT=$((3032 + SLOT * STRIDE))
export TERMINAL_DAEMON_PORT=$((9718 + SLOT * STRIDE))
export POSTGRES_PORT=$((5444 + SLOT * STRIDE))
export REDIS_PORT=$((6389 + SLOT * STRIDE))
export NATS_CLIENT_PORT=$((4222 + SLOT * STRIDE))
export NATS_MONITOR_PORT=$((8222 + SLOT * STRIDE))
export TEMPORAL_PORT=$((7233 + SLOT * STRIDE))
export TEMPORAL_UI_PORT=$((8233 + SLOT * STRIDE))
export TILT_PORT=$((10358 + SLOT * STRIDE))
export CADDY_PORT=$((3009 + SLOT * STRIDE))

# --- URLs (derived from ports — the whole point) ----------------------------
export DATABASE_URL="postgresql://postgres:postgres@localhost:${POSTGRES_PORT}/piano_dev"
export REDIS_URL="redis://localhost:${REDIS_PORT}"
export NATS_URL="nats://localhost:${NATS_CLIENT_PORT}"
export TEMPORAL_ADDRESS="localhost:${TEMPORAL_PORT}"
# Single edge — Caddy fronts everything so dev mirrors prod/staging
# topology (one origin), kills cross-port CORS class of bugs, gives one
# OAuth redirect URI per slot instead of five.
# EDGE_HOST defaults to localhost; .envrc.local can override it.
EDGE_HOST="${EDGE_HOST:-localhost}"
export EDGE_HOST
export EDGE_URL="http://${EDGE_HOST}:${CADDY_PORT}"
export BACKEND_URL="${EDGE_URL}"
export BETTER_AUTH_URL="${EDGE_URL}"
export NEXT_PUBLIC_API_URL="${EDGE_URL}"
export TRUSTED_ORIGINS="${EDGE_URL}"
# Terminal WS goes through backend proxy at /api/terminal/:machineId — that's
# the default. Set NEXT_PUBLIC_TERMINAL_DAEMON_URL only if you're debugging
# against a directly-reachable daemon listener (bypasses auth).
export FRONTEND_HOST=localhost

# --- App config (non-secret, non-port) --------------------------------------
export NODE_ENV=development
export LOG_LEVEL=info

# Dev daemon shortcut: backend ensures a Daemon row keyed on this token's
# hash; daemon binary launches with --token same value. Same Bearer-auth
# path as production, just bootstrapped without the UI pair-code dance.
# Slot-derived so two parallel dev instances don't share a daemon row.
export PIANO_DEV_DAEMON_TOKEN="dev-daemon-token-slot-${SLOT}"
# Optional — pin the dev daemon to a specific user. If unset, attaches to
# the first user in the DB on backend start.
# export PIANO_DEV_DAEMON_USER_EMAIL="you@example.com"

# Sish reverse-tunnel — runs as a docker-compose service in dev (see
# docker-compose.dev.yml). Daemon dials localhost:2222 to register its
# tunnel; sish exposes the public side on PIANO_DEV_SISH_PORT.
# Slot-derived so parallel dev instances don't collide on the same port.
export PIANO_SISH_HOST=localhost
export PIANO_SISH_PORT_RANGE_START=22000
export PIANO_SISH_PORT_RANGE_END=22099
export PIANO_DEV_SISH_PORT=$((22000 + SLOT * STRIDE))

# Daemon's SSH gateway listen port. Sish reverse-forwards to this port on
# the daemon host. Slot-derived so parallel daemons don't fight for it.
export PIANO_DEV_SSH_GATEWAY_PORT=$((2200 + SLOT * STRIDE))

# Default workdir for the dev daemon — surfaces in the "Open in Cursor"
# URL. Containers mount $HOME from host so this path is readable by the
# in-container user (same uid). Production daemons report this themselves
# during pair via Daemon.DTO.Pair.defaultWorkdir.
export PIANO_DEV_DAEMON_DEFAULT_WORKDIR=$HOME

# --- Telemetry (optional: OpenTelemetry → Google Cloud Trace) ----------------
# Off by default. To enable, set ENABLE_TELEMETRY=1 and point
# GOOGLE_CLOUD_PROJECT at your own GCP project, then run once per machine:
#   gcloud auth application-default login
# export ENABLE_TELEMETRY=1
export GOOGLE_CLOUD_PROJECT="${GOOGLE_CLOUD_PROJECT:-}"
export OTEL_RESOURCE_ATTRIBUTES="deployment.environment=dev,user=$(whoami)"

# --- Secrets (gitignored, not checked in) ------------------------------------
source_env_if_exists .env.secrets

# --- Generate .env.local for tools that don't go through direnv --------------
# (Next.js reads .env.local for NEXT_PUBLIC_* at dev time; docker-compose
#  reads it via env_file; IDEs read it for run configs.)
# This block runs every time direnv reloads — .env.local is now a generated
# artifact, not a hand-edited file. If you need to change ports, change SLOT
# above. If you need to change secrets, edit .env.secrets.
cat > .env.local <<EOF
# AUTO-GENERATED by .envrc — do not edit by hand.
# Change ports: edit SLOT in .envrc, then \`direnv allow\`.
# Change secrets: edit .env.secrets.

# Ports (slot ${SLOT}, stride ${STRIDE})
BACKEND_PORT=${BACKEND_PORT}
FRONTEND_PORT=${FRONTEND_PORT}
TERMINAL_DAEMON_PORT=${TERMINAL_DAEMON_PORT}
POSTGRES_PORT=${POSTGRES_PORT}
REDIS_PORT=${REDIS_PORT}
NATS_CLIENT_PORT=${NATS_CLIENT_PORT}
NATS_MONITOR_PORT=${NATS_MONITOR_PORT}
TEMPORAL_PORT=${TEMPORAL_PORT}
TEMPORAL_UI_PORT=${TEMPORAL_UI_PORT}
TILT_PORT=${TILT_PORT}
CADDY_PORT=${CADDY_PORT}

# Edge (host + port)
EDGE_HOST=${EDGE_HOST}

# Derived URLs
DATABASE_URL=${DATABASE_URL}
REDIS_URL=${REDIS_URL}
NATS_URL=${NATS_URL}
TEMPORAL_ADDRESS=${TEMPORAL_ADDRESS}
EDGE_URL=${EDGE_URL}
BACKEND_URL=${BACKEND_URL}
BETTER_AUTH_URL=${BETTER_AUTH_URL}
NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
TRUSTED_ORIGINS=${TRUSTED_ORIGINS}
FRONTEND_HOST=${FRONTEND_HOST}

# App config
NODE_ENV=${NODE_ENV}
LOG_LEVEL=${LOG_LEVEL}
PIANO_DEV_DAEMON_TOKEN=${PIANO_DEV_DAEMON_TOKEN}
PIANO_SISH_HOST=${PIANO_SISH_HOST}
PIANO_SISH_PORT_RANGE_START=${PIANO_SISH_PORT_RANGE_START}
PIANO_SISH_PORT_RANGE_END=${PIANO_SISH_PORT_RANGE_END}
PIANO_DEV_SISH_PORT=${PIANO_DEV_SISH_PORT}
PIANO_DEV_SSH_GATEWAY_PORT=${PIANO_DEV_SSH_GATEWAY_PORT}
PIANO_DEV_DAEMON_DEFAULT_WORKDIR=${PIANO_DEV_DAEMON_DEFAULT_WORKDIR}

# Telemetry
ENABLE_TELEMETRY=${ENABLE_TELEMETRY}
GOOGLE_CLOUD_PROJECT=${GOOGLE_CLOUD_PROJECT}
OTEL_RESOURCE_ATTRIBUTES=${OTEL_RESOURCE_ATTRIBUTES}
EOF

# Append secrets to .env.local so docker-compose env_file picks them up too.
if [ -f .env.secrets ]; then
  echo "" >> .env.local
  echo "# Secrets (from .env.secrets)" >> .env.local
  cat .env.secrets >> .env.local
fi
